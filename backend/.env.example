# ---- Server ----
PORT=5001
NODE_ENV=development

# Allowed frontend origin(s) for CORS (comma-separated).
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ---- MySQL Database ----
# Local MySQL defaults to port 3306. Railway provides its own host/port/creds.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=budget_ai

# ---- JWT Authentication ----
# Use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret

# ---- Ollama (AI provider) ----
# Install Ollama and pull the model locally:
# ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
